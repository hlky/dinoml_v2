static inline float {{ func }}_iou(const float* lhs, const float* rhs) {
  const float inter_x1 = std::max(lhs[0], rhs[0]);
  const float inter_y1 = std::max(lhs[1], rhs[1]);
  const float inter_x2 = std::min(lhs[2], rhs[2]);
  const float inter_y2 = std::min(lhs[3], rhs[3]);
  const float inter_w = std::max(inter_x2 - inter_x1, 0.0f);
  const float inter_h = std::max(inter_y2 - inter_y1, 0.0f);
  const float intersection = inter_w * inter_h;
  const float lhs_area = std::max(lhs[2] - lhs[0], 0.0f) * std::max(lhs[3] - lhs[1], 0.0f);
  const float rhs_area = std::max(rhs[2] - rhs[0], 0.0f) * std::max(rhs[3] - rhs[1], 0.0f);
  const float union_area = lhs_area + rhs_area - intersection;
  return union_area <= 0.0f ? 0.0f : (intersection / union_area);
}

static inline void {{ func }}_load_box(const {{ storage_type }}* src, float* dst) {
  for (int64_t coord = 0; coord < 4; ++coord) {
    dst[coord] = dinoml::math::cast<float>(src[coord]);
  }
}

