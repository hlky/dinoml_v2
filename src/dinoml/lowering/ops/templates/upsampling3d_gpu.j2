struct {{ func }}_interp2<dinoml::bfloat162> {
  __device__ __forceinline__ static float2 to_float2(const dinoml::bfloat162& value) {
    return __bfloat1622float2(value);
  }

  __device__ __forceinline__ static dinoml::bfloat162 from_float2(const float2& value) {
    return __float22bfloat162_rn(value);
  }
