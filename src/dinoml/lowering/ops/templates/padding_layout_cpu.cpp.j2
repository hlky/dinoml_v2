static int {{ func }}(
    const {{ storage_type }}* DINO_RESTRICT x,
    {{ storage_type }}* DINO_RESTRICT y,
    int64_t runtime_numel) {
  if (x == nullptr || y == nullptr) {
    return dino_runtime_fail("{{ func }} received null pointer");
  }
  if ((runtime_numel % {{ padded_channels }}) != 0) {
    return dino_runtime_fail("{{ func }} received invalid output numel");
  }
  const {{ storage_type }} zero_value = dinoml::math::cast<{{ storage_type }}>(0.0f);
  const int64_t positions = runtime_numel / {{ padded_channels }};
#if defined(_OPENMP)
#pragma omp parallel for schedule(static)
#endif
  for (int64_t pos = 0; pos < positions; ++pos) {
    const int64_t input_base = pos * 3;
    const int64_t output_base = pos * {{ padded_channels }};
    y[output_base] = x[input_base];
    y[output_base + 1] = x[input_base + 1];
    y[output_base + 2] = x[input_base + 2];
{% for channel in range(3, padded_channels) %}
    y[output_base + {{ channel }}] = zero_value;
{% endfor %}
  }
  return 0;
}
