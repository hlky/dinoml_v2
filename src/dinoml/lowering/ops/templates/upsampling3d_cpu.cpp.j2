template <typename Elem>
inline Elem {{ func }}_cpu_elem_add(Elem a, Elem b) {
  return dinoml::math::from_float<Elem>(dinoml::math::to_float(a) + dinoml::math::to_float(b));
}

template <typename Elem, int Alignment>
struct alignas(sizeof(Elem) * Alignment) {{ func }}_cpu_pack {
  Elem lanes[Alignment];
};

template <typename Elem, int Alignment>
inline {{ func }}_cpu_pack<Elem, Alignment> {{ func }}_cpu_pack_add(
    const {{ func }}_cpu_pack<Elem, Alignment>& a,
    const {{ func }}_cpu_pack<Elem, Alignment>& b) {
  {{ func }}_cpu_pack<Elem, Alignment> out{};
  for (int lane = 0; lane < Alignment; ++lane) {
    out.lanes[lane] = {{ func }}_cpu_elem_add<Elem>(a.lanes[lane], b.lanes[lane]);
  }
  return out;
}

template <typename Elem, bool AlignCorners, bool HasResidual>
inline void {{ func }}_cpu_trilinear_scalar(
    const Elem* x,
    const Elem* residual,
    Elem* y,
    int64_t batch,
    int64_t in_f,
    int64_t in_h,
    int64_t in_w,
    int64_t channels,
    int64_t out_f,
    int64_t out_h,
    int64_t out_w) {
  const float frame_scale = AlignCorners
      ? ((in_f <= 1 || out_f <= 1) ? 0.0f : static_cast<float>(in_f - 1) / static_cast<float>(out_f - 1))
      : {{ inverse_scale_factor_literal }};
  const float height_scale = AlignCorners
      ? ((in_h <= 1 || out_h <= 1) ? 0.0f : static_cast<float>(in_h - 1) / static_cast<float>(out_h - 1))
      : {{ inverse_scale_factor_literal }};
  const float width_scale = AlignCorners
      ? ((in_w <= 1 || out_w <= 1) ? 0.0f : static_cast<float>(in_w - 1) / static_cast<float>(out_w - 1))
      : {{ inverse_scale_factor_literal }};
#if defined(_OPENMP)
#pragma omp parallel for schedule(static)
#endif
  for (int64_t idx = 0; idx < batch * out_f * out_h * out_w * channels; ++idx) {
    int64_t t = idx;
    const int64_t c = t % channels;
    t /= channels;
    const int64_t out_x = t % out_w;
    t /= out_w;
    const int64_t out_y = t % out_h;
    t /= out_h;
    const int64_t out_frame = t % out_f;
    const int64_t n = t / out_f;
    const float in_frame = AlignCorners
        ? static_cast<float>(out_frame) * frame_scale
        : (static_cast<float>(out_frame) + 0.5f) * frame_scale - 0.5f;
    const float in_y = AlignCorners
        ? static_cast<float>(out_y) * height_scale
        : (static_cast<float>(out_y) + 0.5f) * height_scale - 0.5f;
    const float in_x = AlignCorners
        ? static_cast<float>(out_x) * width_scale
        : (static_cast<float>(out_x) + 0.5f) * width_scale - 0.5f;
    const int64_t f0 = in_frame > 0.0f ? static_cast<int64_t>(floorf(in_frame)) : 0;
    const int64_t f1 = in_frame < static_cast<float>(in_f - 1) ? static_cast<int64_t>(ceilf(in_frame)) : (in_f - 1);
    const int64_t y0 = in_y > 0.0f ? static_cast<int64_t>(floorf(in_y)) : 0;
    const int64_t y1 = in_y < static_cast<float>(in_h - 1) ? static_cast<int64_t>(ceilf(in_y)) : (in_h - 1);
    const int64_t x0 = in_x > 0.0f ? static_cast<int64_t>(floorf(in_x)) : 0;
    const int64_t x1 = in_x < static_cast<float>(in_w - 1) ? static_cast<int64_t>(ceilf(in_x)) : (in_w - 1);
    const float f_lerp = in_frame - floorf(in_frame);
    const float y_lerp = in_y - floorf(in_y);
    const float x_lerp = in_x - floorf(in_x);
    const float v000 = dinoml::math::to_float(x[(((n * in_f + f0) * in_h + y0) * in_w + x0) * channels + c]);
    const float v001 = dinoml::math::to_float(x[(((n * in_f + f0) * in_h + y0) * in_w + x1) * channels + c]);
    const float v010 = dinoml::math::to_float(x[(((n * in_f + f0) * in_h + y1) * in_w + x0) * channels + c]);
    const float v011 = dinoml::math::to_float(x[(((n * in_f + f0) * in_h + y1) * in_w + x1) * channels + c]);
    const float v100 = dinoml::math::to_float(x[(((n * in_f + f1) * in_h + y0) * in_w + x0) * channels + c]);
    const float v101 = dinoml::math::to_float(x[(((n * in_f + f1) * in_h + y0) * in_w + x1) * channels + c]);
    const float v110 = dinoml::math::to_float(x[(((n * in_f + f1) * in_h + y1) * in_w + x0) * channels + c]);
    const float v111 = dinoml::math::to_float(x[(((n * in_f + f1) * in_h + y1) * in_w + x1) * channels + c]);
    const float v00 = v000 + (v001 - v000) * x_lerp;
    const float v01 = v010 + (v011 - v010) * x_lerp;
    const float v10 = v100 + (v101 - v100) * x_lerp;
    const float v11 = v110 + (v111 - v110) * x_lerp;
    const float vy0 = v00 + (v01 - v00) * y_lerp;
    const float vy1 = v10 + (v11 - v10) * y_lerp;
    float out_value = vy0 + (vy1 - vy0) * f_lerp;
    if constexpr (HasResidual) {
      out_value += dinoml::math::to_float(residual[idx]);
    }
    y[idx] = dinoml::math::from_float<Elem>(out_value);
  }
}

template <typename Elem, bool AlignCorners, bool HasResidual>
inline void {{ func }}_cpu_trilinear_packed2(
    const Elem* x_raw,
    const Elem* residual_raw,
    Elem* y_raw,
    int64_t batch,
    int64_t in_f,
    int64_t in_h,
