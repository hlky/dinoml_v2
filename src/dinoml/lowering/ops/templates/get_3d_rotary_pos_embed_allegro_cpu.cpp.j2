  constexpr int64_t grid_total = num_frames * grid_h * grid_w;
  if (
      t_cos_total != num_frames * dim_axis || t_sin_total != num_frames * dim_axis ||
      h_cos_total != grid_h * dim_axis || h_sin_total != grid_h * dim_axis ||
      w_cos_total != grid_w * dim_axis || w_sin_total != grid_w * dim_axis ||
      grid_t_total != grid_total || grid_h_total != grid_total || grid_w_total != grid_total) {
    return dino_runtime_fail("{{ func }} received mismatched output element counts");
