__global__ void {{ kernel }}_table(
    {{ storage_type }}* DINO_RESTRICT cos_out,
    {{ storage_type }}* DINO_RESTRICT sin_out,
    int64_t rows,
    float inv_interp) {
  constexpr int64_t dim_axis = {{ dim_axis }};
  constexpr int64_t pair_dim = {{ pair_dim }};
  constexpr float neg_log_theta = {{ neg_log_theta_literal }};
  const int64_t linear_idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
  const int64_t total = rows * dim_axis;
  if (linear_idx >= total) {
    return;
  }
  const int64_t row = linear_idx / dim_axis;
  const int64_t col = linear_idx - row * dim_axis;
  const int64_t pair_idx = col < pair_dim ? col : (col - pair_dim);
  const float exponent = (neg_log_theta * static_cast<float>(pair_idx)) / static_cast<float>(pair_dim);
  const float angle = (static_cast<float>(row) * inv_interp) * expf(exponent);
  cos_out[linear_idx] = dinoml::math::cast<{{ storage_type }}>(cosf(angle));
  sin_out[linear_idx] = dinoml::math::cast<{{ storage_type }}>(sinf(angle));
}

__global__ void {{ kernel }}_grid(
    {{ grid_storage_type }}* DINO_RESTRICT grid_t,
    {{ grid_storage_type }}* DINO_RESTRICT grid_h_out,
    {{ grid_storage_type }}* DINO_RESTRICT grid_w_out) {
