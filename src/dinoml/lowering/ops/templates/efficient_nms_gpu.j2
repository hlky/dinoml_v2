      runtime_scores != {{ batch }} * {{ num_boxes }} * {{ num_classes }} ||
      runtime_num_det != {{ batch }} ||
      runtime_det_boxes != {{ batch }} * {{ max_output }} * 4 ||
      runtime_det_scores != {{ batch }} * {{ max_output }} ||
      runtime_det_classes != {{ batch }} * {{ max_output }}) {
    return dino_runtime_fail("{{ func }} received mismatched tensor sizes");
  }
  if ({{ batch }} > 0) {
    {{ func }}_kernel<<<{{ batch }}, {{ block_size }}, 0, stream>>>(
        boxes,
        scores,
        num_det,
        det_boxes,
        det_scores,
        det_classes);
    {{ gpu_check_macro }}({{ gpu_last_error_call }});
  }
  return 0;
}
