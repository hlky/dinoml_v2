static int {{ func }}(
    const {{ storage_type }}* DINO_RESTRICT x,
    int64_t runtime_numel_x,
    const {{ storage_type }}* DINO_RESTRICT weight,
    int64_t runtime_numel_weight,
    const {{ storage_type }}* DINO_RESTRICT bias,
    int64_t runtime_numel_bias,
{% if apply_residual %}
    const {{ storage_type }}* DINO_RESTRICT residual,
    int64_t runtime_numel_residual,
{% endif %}
    {{ storage_type }}* DINO_RESTRICT out,
    int64_t runtime_numel_out) {
  if (x == nullptr || weight == nullptr || bias == nullptr || out == nullptr{% if apply_residual %} || residual == nullptr{% endif %}) {
    return dino_runtime_fail("{{ func }} received null pointer");
  }
  if (runtime_numel_x != {{ input_numel }}) {
    return dino_runtime_fail("{{ func }} runtime activation size mismatch");
  }
  if (runtime_numel_weight != {{ weight_numel }}) {
    return dino_runtime_fail("{{ func }} runtime weight size mismatch");
  }
  if (runtime_numel_bias != {{ bias_numel }}) {
    return dino_runtime_fail("{{ func }} runtime bias size mismatch");
  }
{% if apply_residual %}
  if (runtime_numel_residual != {{ residual_numel }}) {
    return dino_runtime_fail("{{ func }} runtime residual size mismatch");
  }
{% endif %}
  if (runtime_numel_out != {{ output_numel }}) {
    return dino_runtime_fail("{{ func }} runtime output size mismatch");
  }
#if defined(_OPENMP)
#pragma omp parallel for collapse(2) schedule(static)
#endif
  for (int64_t batch = 0; batch < {{ batch }}; ++batch) {
    for (int64_t out_channel = 0; out_channel < {{ out_channels }}; ++out_channel) {
      for (int64_t out_h = 0; out_h < {{ out_height }}; ++out_h) {
        const int64_t h_start = out_h * {{ stride_h }} - {{ pad_h }};
        for (int64_t out_w = 0; out_w < {{ out_width }}; ++out_w) {
          const int64_t w_start = out_w * {{ stride_w }} - {{ pad_w }};
          float acc = dinoml::math::cast<float>(bias[out_channel]);
          for (int64_t in_channel = 0; in_channel < {{ in_channels }}; ++in_channel) {
            for (int64_t kernel_h = 0; kernel_h < {{ kernel_h }}; ++kernel_h) {
              const int64_t in_h = h_start + kernel_h * {{ dilation_h }};
              if (in_h < 0 || in_h >= {{ in_height }}) {
                continue;
              }
              for (int64_t kernel_w = 0; kernel_w < {{ kernel_w }}; ++kernel_w) {
                const int64_t in_w = w_start + kernel_w * {{ dilation_w }};
                if (in_w < 0 || in_w >= {{ in_width }}) {
                  continue;
                }
                const int64_t x_index =
                    ((batch * {{ in_channels }} + in_channel) * {{ in_height }} + in_h) * {{ in_width }} + in_w;
                const int64_t weight_index =
                    ((out_channel * {{ in_channels }} + in_channel) * {{ kernel_h }} + kernel_h) * {{ kernel_w }} + kernel_w;
                acc += dinoml::math::cast<float>(x[x_index]) * dinoml::math::cast<float>(weight[weight_index]);
              }
            }
          }
          const int64_t out_index =
              ((batch * {{ out_channels }} + out_channel) * {{ out_height }} + out_h) * {{ out_width }} + out_w;
{% if apply_residual %}
          acc += dinoml::math::cast<float>(residual[out_index]);
{% endif %}
{% if apply_relu %}
          acc = acc > 0.0f ? acc : 0.0f;
{% endif %}
          out[out_index] = dinoml::math::cast<{{ storage_type }}>(acc);
        }
      }
    }
  }
  return 0;
}
