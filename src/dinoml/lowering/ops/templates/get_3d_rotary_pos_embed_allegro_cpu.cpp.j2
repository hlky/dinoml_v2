  {{ func }}_write_table(t_cos, t_sin, num_frames, {{ inv_interp_t_literal }});
  {{ func }}_write_table(h_cos, h_sin, grid_h, {{ inv_interp_h_literal }});
  {{ func }}_write_table(w_cos, w_sin, grid_w, {{ inv_interp_w_literal }});
#if defined(_OPENMP)
#pragma omp parallel for schedule(static)
#endif
  for (int64_t idx = 0; idx < grid_total; ++idx) {
    const int64_t t_idx = idx / (grid_h * grid_w);
    const int64_t spatial_idx = idx - t_idx * grid_h * grid_w;
    const int64_t h_idx = spatial_idx / grid_w;
    const int64_t w_idx = spatial_idx - h_idx * grid_w;
