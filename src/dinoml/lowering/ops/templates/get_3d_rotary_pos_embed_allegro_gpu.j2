  constexpr int64_t grid_h = {{ grid_h }};
  constexpr int64_t grid_w = {{ grid_w }};
  const int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
  const int64_t total = num_frames * grid_h * grid_w;
  if (idx >= total) {
    return;
  }
  const int64_t t_idx = idx / (grid_h * grid_w);
  const int64_t spatial_idx = idx - t_idx * grid_h * grid_w;
  const int64_t h_idx = spatial_idx / grid_w;
  const int64_t w_idx = spatial_idx - h_idx * grid_w;
  grid_t[idx] = static_cast<{{ grid_storage_type }}>(t_idx);
  grid_h_out[idx] = static_cast<{{ grid_storage_type }}>(h_idx);
  grid_w_out[idx] = static_cast<{{ grid_storage_type }}>(w_idx);
}

