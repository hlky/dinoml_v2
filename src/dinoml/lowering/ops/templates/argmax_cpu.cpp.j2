static int {{ func }}(
    const {{ input_storage_type }}* DINO_RESTRICT x,
    {{ output_storage_type }}* DINO_RESTRICT y,
    int64_t runtime_rows) {
  if (x == nullptr || y == nullptr) {
    return dino_runtime_fail("{{ func }} received null pointer");
  }
  constexpr int64_t cols = {{ cols }};
#if defined(_OPENMP)
#pragma omp parallel for schedule(static)
#endif
  for (int64_t row = 0; row < runtime_rows; ++row) {
    const int64_t base = row * cols;
    int64_t best_index = 0;
{% if input_is_bool %}
    bool best_value = x[base];
    for (int64_t col = 1; col < cols; ++col) {
      const bool value = x[base + col];
      if (value > best_value) {
        best_value = value;
        best_index = col;
      }
    }
{% elif input_is_integer %}
    {{ input_storage_type }} best_value = x[base];
    for (int64_t col = 1; col < cols; ++col) {
      const {{ input_storage_type }} value = x[base + col];
      if (value > best_value) {
        best_value = value;
        best_index = col;
      }
    }
{% else %}
    float best_value = dinoml::math::cast<float>(x[base]);
    for (int64_t col = 1; col < cols; ++col) {
      const float value = dinoml::math::cast<float>(x[base + col]);
      if ((value > best_value) || (std::isnan(value) && !std::isnan(best_value))) {
        best_value = value;
        best_index = col;
      }
    }
{% endif %}
    y[row] = best_index;
  }
  return 0;
}
