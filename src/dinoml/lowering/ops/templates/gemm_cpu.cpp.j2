static int {{ func }}(
    const {{ storage_type }}* DINO_RESTRICT a,
    int64_t runtime_numel_a,
    const {{ storage_type }}* DINO_RESTRICT b,
    int64_t runtime_numel_b,
{% if has_bias %}
    const {{ storage_type }}* DINO_RESTRICT bias,
    int64_t runtime_numel_bias,
{% endif %}
    {{ storage_type }}* DINO_RESTRICT c,
    int64_t runtime_numel_c,
    int64_t runtime_m,
    int64_t runtime_n,
    int64_t runtime_k) {
  if (a == nullptr || b == nullptr || c == nullptr{% if has_bias %} || bias == nullptr{% endif %}) {
    return dino_runtime_fail("{{ func }} received null pointer");
  }
  if (runtime_m < 0 || runtime_n <= 0 || runtime_k <= 0) {
    return dino_runtime_fail("{{ func }} received invalid runtime GEMM shape");
  }
  if (runtime_numel_a != runtime_m * runtime_k) {
    return dino_runtime_fail("{{ func }} runtime A size mismatch");
  }
  if (runtime_numel_b != runtime_n * runtime_k) {
    return dino_runtime_fail("{{ func }} runtime B size mismatch");
  }
{% if has_bias %}
  if (runtime_numel_bias != runtime_n) {
    return dino_runtime_fail("{{ func }} runtime bias size mismatch");
  }
{% endif %}
  if (runtime_numel_c != runtime_m * runtime_n) {
    return dino_runtime_fail("{{ func }} runtime output size mismatch");
  }
#if defined(_OPENMP)
#pragma omp parallel for schedule(static)
#endif
  for (int64_t row = 0; row < runtime_m; ++row) {
    const int64_t a_base = row * runtime_k;
    const int64_t c_base = row * runtime_n;
    for (int64_t col = 0; col < runtime_n; ++col) {
      float acc = 0.0f;
      const int64_t b_base = col * runtime_k;
      for (int64_t kk = 0; kk < runtime_k; ++kk) {
        acc += dinoml::math::cast<float>(a[a_base + kk]) * dinoml::math::cast<float>(b[b_base + kk]);
      }
{% if has_bias %}
      acc += dinoml::math::cast<float>(bias[col]);
{% endif %}
{% if activation == "fast_gelu" %}
      acc = acc / (1.0f + std::exp(-1.702f * acc));
{% endif %}
      c[c_base + col] = dinoml::math::cast<{{ storage_type }}>(acc);
    }
  }
  return 0;
}
