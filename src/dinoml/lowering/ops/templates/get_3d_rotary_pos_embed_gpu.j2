  if (cos_total != total_values || sin_total != total_values) {
    return dino_runtime_fail("{{ func }} received mismatched output element counts");
  }
  const int block = {{ block_size }};
  const int grid = static_cast<int>((total_values + block - 1) / block);
  {{ kernel }}<<<grid, block, 0, stream>>>(cos_out, sin_out);
  {{ gpu_check_macro }}({{ gpu_last_error_call }});
  return 0;
}
