static void {{ func }}_write_table(
    {{ storage_type }}* DINO_RESTRICT cos_out,
    {{ storage_type }}* DINO_RESTRICT sin_out,
    int64_t rows,
    float inv_interp) {
  constexpr int64_t dim_axis = {{ dim_axis }};
  constexpr int64_t pair_dim = {{ pair_dim }};
  constexpr float neg_log_theta = {{ neg_log_theta_literal }};
  for (int64_t row = 0; row < rows; ++row) {
    const int64_t base = row * dim_axis;
    const float position = static_cast<float>(row) * inv_interp;
    for (int64_t col = 0; col < dim_axis; ++col) {
      const int64_t pair_idx = col < pair_dim ? col : (col - pair_dim);
      const float exponent = (neg_log_theta * static_cast<float>(pair_idx)) / static_cast<float>(pair_dim);
      const float angle = position * expf(exponent);
      cos_out[base + col] = dinoml::math::cast<{{ storage_type }}>(cosf(angle));
      sin_out[base + col] = dinoml::math::cast<{{ storage_type }}>(sinf(angle));
    }
  }
}

static int {{ func }}(
