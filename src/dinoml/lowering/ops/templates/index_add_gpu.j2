template <typename T>
__device__ __forceinline__ void {{ func }}_atomic_add_16(T* addr, float value) {
  const uintptr_t address = reinterpret_cast<uintptr_t>(addr);
  auto* word_ptr = reinterpret_cast<unsigned int*>(address & ~static_cast<uintptr_t>(0x3));
  const bool upper = (address & 0x2u) != 0;
  unsigned int old_word = *word_ptr;
  unsigned int assumed_word = 0;
  do {
    assumed_word = old_word;
    const uint16_t old_bits = upper
        ? static_cast<uint16_t>((assumed_word >> 16) & 0xffffu)
        : static_cast<uint16_t>(assumed_word & 0xffffu);
    const float sum = dinoml::math::cast<float>({{ func }}_from_bits<T>(old_bits)) + value;
    const uint16_t new_bits = {{ func }}_bits(dinoml::math::cast<T>(sum));
    const unsigned int new_word = upper
        ? ((assumed_word & 0x0000ffffu) | (static_cast<unsigned int>(new_bits) << 16))
        : ((assumed_word & 0xffff0000u) | static_cast<unsigned int>(new_bits));
    old_word = atomicCAS(word_ptr, assumed_word, new_word);
  } while (old_word != assumed_word);
}

