  }
  if ((in_c % {{ nearest_alignment }}) != 0) {
    return dino_runtime_fail("{{ func }} requires channels divisible by {{ nearest_alignment }} for packed nearest upsampling");
  }
  const int block = {{ block_size }};
  const int64_t grid64 = (runtime_numel + block - 1) / block;
  const int grid = static_cast<int>(grid64 > 65535 ? 65535 : grid64);
  if (grid <= 0) {
    return 0;
  }
  using DinoUpsampling3dCompressTimeVec = {{ nearest_vec_type }};
  {{ kernel }}_nearest<
      {{ storage_type }},
      DinoUpsampling3dCompressTimeVec,
      {{ nearest_alignment }}>
      <<<grid, block, 0, stream>>>(
          reinterpret_cast<const DinoUpsampling3dCompressTimeVec*>(x),
          reinterpret_cast<DinoUpsampling3dCompressTimeVec*>(y),
          in_n,
          in_f,
          in_h,
          in_w,
          in_c / {{ nearest_alignment }},
          out_f,
          out_h,
          out_w);
  {{ gpu_check_macro }}({{ gpu_last_error_call }});
  return 0;
}
