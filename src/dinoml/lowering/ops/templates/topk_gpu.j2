  uint32_t total = 0u;
  for (int tile = 0; tile < tiles_per_row; ++tile) {
    total += counts[(row * static_cast<int64_t>(tiles_per_row) + tile) * 256 + bin];
  }
  bin_counts[bin] = total;
  __syncthreads();

  if (threadIdx.x == 0) {
    const int previous_prefix = pass == 0 ? 0 : prefixes[row];
    int rem = pass == 0 ? {{ k }} : remaining[row];
    int skipped = 0;
    int chosen = 0;
    for (int current_bin = 255; current_bin >= 0; --current_bin) {
      const int count = static_cast<int>(bin_counts[current_bin]);
      if (skipped + count >= rem) {
        chosen = current_bin;
        rem -= skipped;
        break;
      }
      skipped += count;
