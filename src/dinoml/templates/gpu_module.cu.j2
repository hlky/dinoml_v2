DINO_EXPORT int dino_session_get_output_shape(
    DinoSession* session,
    size_t output_index,
    int64_t* out_shape,
    size_t* inout_ndim) {
  if (session == nullptr || inout_ndim == nullptr) {
    return dinoml::module::fail("dino_session_get_output_shape received null argument");
  }
  if (output_index >= session->last_output_shapes.size()) {
    return dinoml::module::fail("dino_session_get_output_shape received invalid output index");
  }
  const std::vector<int64_t>& shape = session->last_output_shapes[output_index];
  if (!session->last_output_shapes_valid[output_index]) {
    *inout_ndim = 0;
    return dinoml::module::fail("Output shape is unavailable before dino_session_run");
  }
  const size_t rank = shape.size();
  if (out_shape == nullptr) {
    *inout_ndim = rank;
    return 0;
  }
  if (*inout_ndim < rank) {
    *inout_ndim = rank;
    return dinoml::module::fail("Output shape buffer is too small");
  }
  for (size_t i = 0; i < rank; ++i) {
    out_shape[i] = shape[i];
  }
  *inout_ndim = rank;
  return 0;
}

