static int {{ func }}(
    const {{ storage_type }}* DINO_RESTRICT table,
    const {{ index_storage_type }}* DINO_RESTRICT indices,
    {{ storage_type }}* DINO_RESTRICT y,
    int64_t runtime_numel_indices,
    int64_t runtime_numel_out,
    {{ gpu_stream_type }} stream) {
  if (table == nullptr || indices == nullptr || y == nullptr) {
    return dino_runtime_fail("{{ func }} received null pointer");
  }
  if (runtime_numel_out != runtime_numel_indices * {{ hidden_size }}) {
    return dino_runtime_fail("embedding runtime output size mismatch");
  }
  const int block = {{ block_size }};
{% if use_vector_kernel %}
  const int64_t runtime_numel_vec_out = runtime_numel_out / {{ vector_width }};
  const int64_t vector_grid64 = (runtime_numel_vec_out + block - 1) / block;
  const int vector_grid = static_cast<int>(vector_grid64 > 65535 ? 65535 : vector_grid64);
  if (vector_grid > 0) {
    {{ vector_kernel }}<<<vector_grid, block, 0, stream>>>(table, indices, y, runtime_numel_vec_out);
    {{ gpu_check_macro }}({{ gpu_last_error_call }});
  }
{% else %}
  const int64_t grid64 = (runtime_numel_out + block - 1) / block;
  const int grid = static_cast<int>(grid64 > 65535 ? 65535 : grid64);
  if (grid > 0) {
    {{ kernel }}<<<grid, block, 0, stream>>>(table, indices, y, runtime_numel_out);
    {{ gpu_check_macro }}({{ gpu_last_error_call }});
  }
{% endif %}
  return 0;
}
