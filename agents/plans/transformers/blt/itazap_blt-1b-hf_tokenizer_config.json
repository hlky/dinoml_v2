{
  "tokenizer_class": "PreTrainedTokenizerFast",
  "vocab_size": 260,
  "model_max_length": 1024,
  "model_input_names": [
    "input_ids",
    "attention_mask"
  ],
  "add_bos_token": true,
  "add_eos_token": true,
  "bos_token": "<s>",
  "eos_token": "</s>",
  "pad_token": "<pad>",
  "unk_token": "<unk>"
}