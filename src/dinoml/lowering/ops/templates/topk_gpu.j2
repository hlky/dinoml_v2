  } else if (key > keys[1]) {
    pos = 1;
  } else if (key > keys[2]) {
    pos = 2;
  } else if (key > keys[3]) {
    pos = 3;
  } else if (key > keys[4]) {
    pos = 4;
  } else if (key > keys[5]) {
    pos = 5;
  } else if (key > keys[6]) {
    pos = 6;
