    const int64_t within_batch = idx - batch * output_batch_stride_vectors;
    const int64_t k = within_batch / slice_vectors;
    const int64_t selected_index = static_cast<int64_t>(index[batch * gather_count + k]);
    if (selected_index < 0 || selected_index >= source_rows) {
      assert(selected_index >= 0 && selected_index < source_rows);
      return;
    }
    const int64_t input_idx = batch * input_batch_stride_vectors + selected_index * slice_vectors + slice_offset;
    y4[idx] = x4[input_idx];
  }
}

