static int {{ func }}(
    const {{ cpu_storage_type }}* DINO_RESTRICT x,
    {{ cpu_storage_type }}* DINO_RESTRICT y,
    int64_t runtime_rows) {
  if (x == nullptr || y == nullptr) {
    return dino_runtime_fail("{{ func }} received null pointer");
  }
  constexpr int64_t cols = {{ cols }};
#if defined(_OPENMP)
#pragma omp parallel for schedule(static)
#endif
  for (int64_t row = 0; row < runtime_rows; ++row) {
    const int64_t base = row * cols;
    float acc = {{ initial_value }};
{% if two_accumulators %}
    float sum_sq_acc = 0.0f;
{% endif %}
    for (int64_t col = 0; col < cols; ++col) {
      const float value = dinoml::math::cast<float>(x[base + col]);
      acc = {{ combine_expr }};
{% if two_accumulators %}
      sum_sq_acc += value * value;
{% endif %}
    }
    y[row] = dinoml::math::cast<{{ cpu_storage_type }}>({{ final_expr }});
  }
  return 0;
}
