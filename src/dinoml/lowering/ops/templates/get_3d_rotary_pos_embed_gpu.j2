__global__ void {{ kernel }}(
    {{ storage_type }}* DINO_RESTRICT cos_out,
    {{ storage_type }}* DINO_RESTRICT sin_out) {
  constexpr int64_t rows = {{ rows }};
  constexpr int64_t grid_h = {{ grid_h }};
  constexpr int64_t grid_w = {{ grid_w }};
  constexpr int64_t embed_dim = {{ embed_dim }};
  constexpr int64_t dim_t = {{ dim_t }};
  constexpr int64_t dim_h = {{ dim_h }};
  constexpr int64_t pair_dim_t = {{ pair_dim_t }};
  constexpr int64_t pair_dim_h = {{ pair_dim_h }};
  constexpr int64_t pair_dim_w = {{ pair_dim_w }};
  constexpr bool grid_is_slice = {{ "true" if grid_is_slice else "false" }};
  constexpr float crop_start_h = {{ crop_start_h_literal }};
  constexpr float crop_start_w = {{ crop_start_w_literal }};
  constexpr float grid_h_step = {{ grid_h_step_literal }};
  constexpr float grid_w_step = {{ grid_w_step_literal }};
  constexpr float neg_log_theta = {{ neg_log_theta_literal }};
  const int64_t linear_idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
  const int64_t total = rows * embed_dim;
  if (linear_idx >= total) {
    return;
  }
  const int64_t row = linear_idx / embed_dim;
  const int64_t col = linear_idx - row * embed_dim;
  const int64_t t_idx = row / (grid_h * grid_w);
  const int64_t spatial_idx = row - t_idx * grid_h * grid_w;
  const int64_t h_idx = spatial_idx / grid_w;
  const int64_t w_idx = spatial_idx - h_idx * grid_w;
  int64_t pair_idx = 0;
  int64_t pair_dim = 1;
  float position = 0.0f;
  if (col < dim_t) {
    pair_idx = col / 2;
    pair_dim = pair_dim_t;
    position = static_cast<float>(t_idx);
  } else if (col < dim_t + dim_h) {
    pair_idx = (col - dim_t) / 2;
    pair_dim = pair_dim_h;
    position = grid_is_slice ? static_cast<float>(h_idx) : (crop_start_h + static_cast<float>(h_idx) * grid_h_step);
  } else {
    pair_idx = (col - dim_t - dim_h) / 2;
    pair_dim = pair_dim_w;
    position = grid_is_slice ? static_cast<float>(w_idx) : (crop_start_w + static_cast<float>(w_idx) * grid_w_step);
  }
  const float exponent = (neg_log_theta * static_cast<float>(pair_idx)) / static_cast<float>(pair_dim);
  const float angle = position * expf(exponent);
  cos_out[linear_idx] = dinoml::math::cast<{{ storage_type }}>(cosf(angle));
  sin_out[linear_idx] = dinoml::math::cast<{{ storage_type }}>(sinf(angle));
}

