{
  "source": "https://huggingface.co/onnx-community/dinov3-vitl16-chmv2-dpt-head-ONNX/raw/main/config.json",
  "note": "Open ONNX mirror of gated facebook/dinov3-vitl16-chmv2-dpt-head; use as representative config only.",
  "model_type": "chmv2",
