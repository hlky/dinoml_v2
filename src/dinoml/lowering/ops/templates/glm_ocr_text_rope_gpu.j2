__device__ void {{ func }}_apply_text_rope(
    const {{ storage_type }}* DINO_RESTRICT input,
    const {{ trig_storage_type }}* DINO_RESTRICT cos,
    const {{ trig_storage_type }}* DINO_RESTRICT sin,
    {{ storage_type }}* DINO_RESTRICT output,
    int64_t elem,
    int64_t heads) {
  constexpr int64_t seq_len = {{ seq_len }};
  constexpr int64_t head_dim = {{ head_dim }};
  constexpr int64_t trig_dim = {{ trig_dim }};
  constexpr int64_t rotary_dim = {{ rotary_dim }};
  const int64_t col = elem % head_dim;
  float value = dinoml::math::cast<float>(input[elem]);
  if (col < rotary_dim) {
    const int64_t row = elem / head_dim;
    const int64_t seq = (row / heads) % seq_len;
    const int64_t batch = row / (heads * seq_len);
    const int64_t pair_offset = (col & 1) == 0 ? 1 : -1;
    const float pair_value = dinoml::math::cast<float>(input[elem + pair_offset]);
    const float rotated = (col & 1) == 0 ? -pair_value : pair_value;
    const int64_t trig_index = (batch * seq_len + seq) * trig_dim + col / 2;
    const float c = dinoml::math::cast<float>(cos[trig_index]);
    const float s = dinoml::math::cast<float>(sin[trig_index]);
    value = value * c + rotated * s;
  }
  output[elem] = dinoml::math::cast<{{ storage_type }}>(value);
}

