  const float angle = position * expf({{ neg_log_10000_literal }} * static_cast<float>(freq_idx) / static_cast<float>(pair_dim));
  const float value = local_col < pair_dim ? sinf(angle) : cosf(angle);
  y[linear_idx] = dinoml::math::cast<{{ storage_type }}>(value);
}

