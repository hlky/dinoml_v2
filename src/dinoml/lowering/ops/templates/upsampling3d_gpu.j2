struct {{ func }}_interp2<half2> {
  __device__ __forceinline__ static float2 to_float2(const half2& value) {
    return __half22float2(value);
  }

  __device__ __forceinline__ static half2 from_float2(const float2& value) {
    return __float22half2_rn(value);
