{
  "model_repo": "CohereLabs/cohere-transcribe-03-2026",
  "sampling_rate": 16000,
  "num_mel_bins": 128,
  "n_fft": 512,
  "hop_length": 160,
  "win_length": 400,
  "chunk_length": null,
  "vocab_size": 16384,
  "bos_token_id": 4,
  "eos_token_id": 3,
  "pad_token_id": 2,
  "decoder_start_token_id": 13764,
  "d_model": 1280,
  "encoder_layers": 48,
  "decoder_layers": 8,
  "decoder_hidden_size": 1024,
  "opset": 18,
  "dtype": "float32",
  "files": {
    "mel": "mel.onnx",
    "encoder": "encoder.onnx",
    "decoder_init": "decoder_init.onnx",
    "decoder_step": "decoder_step.onnx",
    "config": "config.json"
  },
  "decoder_strategy": "kv_cache",
  "decoder_notes": "decoder_init.onnx produces logits plus self/cross-attention KV for the initial context, then decoder_step.onnx consumes one token at a time with carried KV tensors for O(n) generation.",
  "notes": [
    "Model requires trust_remote_code=True when loading via transformers.",
    "mel.onnx: waveforms [B,T] float32 + waveforms_lens [B] int64 \u2192 features [B,128,F] + features_lens [B].",
    "mel.onnx uses DFT conv1d (no STFT op); dither is disabled \u2014 add 1e-5*randn in training but not inference.",
    "encoder.onnx: input_features [B,128,F] float32 \u2192 encoder_hidden_states [B,F/8,1280] float32.",
    "Default decoder export is KV-cache based: decoder_init.onnx + decoder_step.onnx.",
    "Pass --conventional-decoder to export decoder.onnx instead.",
    "Pass --revision <commit-or-tag> to pin the Hugging Face remote code and model files.",
    "vocab.json is generated from the tokenizer ID mapping; tokenizer.json/model metadata are copied from the Hugging Face snapshot cache when available.",
    "The model is gated on HuggingFace; run `huggingface-cli login` before export."
  ],
  "decoder_kv_cache": {
    "num_layers": 8,
    "num_heads": 8,
    "head_dim": 128,
    "decoder_init_inputs": [
      "decoder_input_ids [1,1] int64",
      "encoder_hidden_states [1,T,1280] float32"
    ],
    "decoder_init_outputs": [
      "logits [1,1,vocab] float32",
      "self_key_0 [1,8,1,128] float32",
      "self_key_1 [1,8,1,128] float32",
      "self_key_2 [1,8,1,128] float32",
      "self_key_3 [1,8,1,128] float32",
      "self_key_4 [1,8,1,128] float32",
      "self_key_5 [1,8,1,128] float32",
      "self_key_6 [1,8,1,128] float32",
      "self_key_7 [1,8,1,128] float32",
      "self_val_0 [1,8,1,128] float32",
      "self_val_1 [1,8,1,128] float32",
      "self_val_2 [1,8,1,128] float32",
      "self_val_3 [1,8,1,128] float32",
      "self_val_4 [1,8,1,128] float32",
      "self_val_5 [1,8,1,128] float32",
      "self_val_6 [1,8,1,128] float32",
      "self_val_7 [1,8,1,128] float32",
      "cross_key_0 [1,8,T',128] float32",
      "cross_key_1 [1,8,T',128] float32",
      "cross_key_2 [1,8,T',128] float32",
      "cross_key_3 [1,8,T',128] float32",
      "cross_key_4 [1,8,T',128] float32",
      "cross_key_5 [1,8,T',128] float32",
      "cross_key_6 [1,8,T',128] float32",
      "cross_key_7 [1,8,T',128] float32",
      "cross_val_0 [1,8,T',128] float32",
      "cross_val_1 [1,8,T',128] float32",
      "cross_val_2 [1,8,T',128] float32",
      "cross_val_3 [1,8,T',128] float32",
      "cross_val_4 [1,8,T',128] float32",
      "cross_val_5 [1,8,T',128] float32",
      "cross_val_6 [1,8,T',128] float32",
      "cross_val_7 [1,8,T',128] float32"
    ],
    "decoder_step_inputs": [
      "decoder_input_ids [1,1] int64",
      "positions [1,1] int64",
      "self_key_0 [1,8,past,128] float32",
      "self_key_1 [1,8,past,128] float32",
      "self_key_2 [1,8,past,128] float32",
      "self_key_3 [1,8,past,128] float32",
      "self_key_4 [1,8,past,128] float32",
      "self_key_5 [1,8,past,128] float32",
      "self_key_6 [1,8,past,128] float32",
      "self_key_7 [1,8,past,128] float32",
      "self_val_0 [1,8,past,128] float32",
      "self_val_1 [1,8,past,128] float32",
      "self_val_2 [1,8,past,128] float32",
      "self_val_3 [1,8,past,128] float32",
      "self_val_4 [1,8,past,128] float32",
      "self_val_5 [1,8,past,128] float32",
      "self_val_6 [1,8,past,128] float32",
      "self_val_7 [1,8,past,128] float32",
      "cross_key_0 [1,8,T',128] float32",
      "cross_key_1 [1,8,T',128] float32",
      "cross_key_2 [1,8,T',128] float32",
      "cross_key_3 [1,8,T',128] float32",
      "cross_key_4 [1,8,T',128] float32",
      "cross_key_5 [1,8,T',128] float32",
      "cross_key_6 [1,8,T',128] float32",
      "cross_key_7 [1,8,T',128] float32",
      "cross_val_0 [1,8,T',128] float32",
      "cross_val_1 [1,8,T',128] float32",
      "cross_val_2 [1,8,T',128] float32",
      "cross_val_3 [1,8,T',128] float32",
      "cross_val_4 [1,8,T',128] float32",
      "cross_val_5 [1,8,T',128] float32",
      "cross_val_6 [1,8,T',128] float32",
      "cross_val_7 [1,8,T',128] float32"
    ],
    "decoder_step_outputs": [
      "logits [1,1,vocab] float32",
      "new_self_key_0 [1,8,past+1,128] float32",
      "new_self_key_1 [1,8,past+1,128] float32",
      "new_self_key_2 [1,8,past+1,128] float32",
      "new_self_key_3 [1,8,past+1,128] float32",
      "new_self_key_4 [1,8,past+1,128] float32",
      "new_self_key_5 [1,8,past+1,128] float32",
      "new_self_key_6 [1,8,past+1,128] float32",
      "new_self_key_7 [1,8,past+1,128] float32",
      "new_self_val_0 [1,8,past+1,128] float32",
      "new_self_val_1 [1,8,past+1,128] float32",
      "new_self_val_2 [1,8,past+1,128] float32",
      "new_self_val_3 [1,8,past+1,128] float32",
      "new_self_val_4 [1,8,past+1,128] float32",
      "new_self_val_5 [1,8,past+1,128] float32",
      "new_self_val_6 [1,8,past+1,128] float32",
      "new_self_val_7 [1,8,past+1,128] float32"
    ],
    "notes": [
      "Run decoder_init once with the start token and encoder hidden states.",
      "decoder_init outputs: logits + 8 self_key + 8 self_val + 8 cross_key + 8 cross_val.",
      "Run decoder_step for each subsequent token; pass self KV from previous step output.",
      "cross_key/cross_val come from decoder_init and are fixed for the whole utterance.",
      "decoder_step self KV outputs are already concatenated (past||new) and can be passed directly to the next step.",
      "positions input to decoder_step = number of tokens decoded so far (1 after init, 2 after step 1, ...)."
    ]
  }
}