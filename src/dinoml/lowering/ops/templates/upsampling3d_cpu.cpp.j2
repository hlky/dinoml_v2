    int64_t out_h,
    int64_t out_w) {
  using Pack2 = {{ func }}_cpu_pack<Elem, 2>;
  const Pack2* x = reinterpret_cast<const Pack2*>(x_raw);
  const Pack2* residual = reinterpret_cast<const Pack2*>(residual_raw);
  Pack2* y = reinterpret_cast<Pack2*>(y_raw);
  const float frame_scale = AlignCorners
      ? ((in_f <= 1 || out_f <= 1) ? 0.0f : static_cast<float>(in_f - 1) / static_cast<float>(out_f - 1))
      : {{ inverse_scale_factor_literal }};
  const float height_scale = AlignCorners
      ? ((in_h <= 1 || out_h <= 1) ? 0.0f : static_cast<float>(in_h - 1) / static_cast<float>(out_h - 1))
      : {{ inverse_scale_factor_literal }};
  const float width_scale = AlignCorners
      ? ((in_w <= 1 || out_w <= 1) ? 0.0f : static_cast<float>(in_w - 1) / static_cast<float>(out_w - 1))
      : {{ inverse_scale_factor_literal }};
#if defined(_OPENMP)
#pragma omp parallel for schedule(static)
#endif
  for (int64_t idx = 0; idx < batch * out_f * out_h * out_w * channels_packed; ++idx) {
    int64_t t = idx;
    const int64_t c = t % channels_packed;
    t /= channels_packed;
    const int64_t out_x = t % out_w;
    t /= out_w;
    const int64_t out_y = t % out_h;
    t /= out_h;
    const int64_t out_frame = t % out_f;
    const int64_t n = t / out_f;
    const float in_frame = AlignCorners
        ? static_cast<float>(out_frame) * frame_scale
        : (static_cast<float>(out_frame) + 0.5f) * frame_scale - 0.5f;
    const float in_y = AlignCorners
        ? static_cast<float>(out_y) * height_scale
        : (static_cast<float>(out_y) + 0.5f) * height_scale - 0.5f;
    const float in_x = AlignCorners
        ? static_cast<float>(out_x) * width_scale
        : (static_cast<float>(out_x) + 0.5f) * width_scale - 0.5f;
    const int64_t f0 = in_frame > 0.0f ? static_cast<int64_t>(floorf(in_frame)) : 0;
    const int64_t f1 = in_frame < static_cast<float>(in_f - 1) ? static_cast<int64_t>(ceilf(in_frame)) : (in_f - 1);
    const int64_t y0 = in_y > 0.0f ? static_cast<int64_t>(floorf(in_y)) : 0;
    const int64_t y1 = in_y < static_cast<float>(in_h - 1) ? static_cast<int64_t>(ceilf(in_y)) : (in_h - 1);
    const int64_t x0 = in_x > 0.0f ? static_cast<int64_t>(floorf(in_x)) : 0;
    const int64_t x1 = in_x < static_cast<float>(in_w - 1) ? static_cast<int64_t>(ceilf(in_x)) : (in_w - 1);
    const float f_lerp = in_frame - floorf(in_frame);
    const float y_lerp = in_y - floorf(in_y);
    const float x_lerp = in_x - floorf(in_x);
    const Pack2 v000 = x[(((n * in_f + f0) * in_h + y0) * in_w + x0) * channels_packed + c];
    const Pack2 v001 = x[(((n * in_f + f0) * in_h + y0) * in_w + x1) * channels_packed + c];
    const Pack2 v010 = x[(((n * in_f + f0) * in_h + y1) * in_w + x0) * channels_packed + c];
    const Pack2 v011 = x[(((n * in_f + f0) * in_h + y1) * in_w + x1) * channels_packed + c];
    const Pack2 v100 = x[(((n * in_f + f1) * in_h + y0) * in_w + x0) * channels_packed + c];
    const Pack2 v101 = x[(((n * in_f + f1) * in_h + y0) * in_w + x1) * channels_packed + c];
    const Pack2 v110 = x[(((n * in_f + f1) * in_h + y1) * in_w + x0) * channels_packed + c];
    const Pack2 v111 = x[(((n * in_f + f1) * in_h + y1) * in_w + x1) * channels_packed + c];
    Pack2 out{};
    for (int lane = 0; lane < 2; ++lane) {
      const float f00 = dinoml::math::to_float(v000.lanes[lane]) +
          (dinoml::math::to_float(v001.lanes[lane]) - dinoml::math::to_float(v000.lanes[lane])) * x_lerp;
      const float f01 = dinoml::math::to_float(v010.lanes[lane]) +
          (dinoml::math::to_float(v011.lanes[lane]) - dinoml::math::to_float(v010.lanes[lane])) * x_lerp;
      const float f10 = dinoml::math::to_float(v100.lanes[lane]) +
          (dinoml::math::to_float(v101.lanes[lane]) - dinoml::math::to_float(v100.lanes[lane])) * x_lerp;
      const float f11 = dinoml::math::to_float(v110.lanes[lane]) +
          (dinoml::math::to_float(v111.lanes[lane]) - dinoml::math::to_float(v110.lanes[lane])) * x_lerp;
      const float fy0 = f00 + (f01 - f00) * y_lerp;
      const float fy1 = f10 + (f11 - f10) * y_lerp;
      out.lanes[lane] = dinoml::math::from_float<Elem>(fy0 + (fy1 - fy0) * f_lerp);
    }
    if constexpr (HasResidual) {
      y[idx] = {{ func }}_cpu_pack_add<Elem, 2>(residual[idx], out);
    } else {
      y[idx] = out;
    }
  }
}

template <typename Elem, int Alignment, bool Exact, bool HasResidual>
inline void {{ func }}_cpu_nearest_packed(
    const Elem* x_raw,
    const Elem* residual_raw,
    Elem* y_raw,
    int64_t batch,
    int64_t in_f,
    int64_t in_h,
    int64_t in_w,
    int64_t channels_packed,
    int64_t out_f,
    int64_t out_h,
    int64_t out_w) {
  using Pack = {{ func }}_cpu_pack<Elem, Alignment>;
  const Pack* x = reinterpret_cast<const Pack*>(x_raw);
  const Pack* residual = reinterpret_cast<const Pack*>(residual_raw);
  Pack* y = reinterpret_cast<Pack*>(y_raw);
  const float frame_scale = {{ inverse_scale_factor_literal }};
  const float height_scale = {{ inverse_scale_factor_literal }};
  const float width_scale = {{ inverse_scale_factor_literal }};
#if defined(_OPENMP)
#pragma omp parallel for schedule(static)
#endif
  for (int64_t idx = 0; idx < batch * out_f * out_h * out_w * channels_packed; ++idx) {
    int64_t t = idx;
    const int64_t c = t % channels_packed;
    t /= channels_packed;
    const int64_t out_x = t % out_w;
    t /= out_w;
    const int64_t out_y = t % out_h;
    t /= out_h;
    const int64_t out_frame = t % out_f;
    const int64_t n = t / out_f;
    int64_t in_frame = 0;
    int64_t in_y = 0;
    int64_t in_x = 0;
    if constexpr (Exact) {
      in_frame = std::max<int64_t>(
          std::min<int64_t>(static_cast<int64_t>(floorf((static_cast<float>(out_frame) + 0.5f) * frame_scale)), in_f - 1),
          0);
      in_y = std::max<int64_t>(
          std::min<int64_t>(static_cast<int64_t>(floorf((static_cast<float>(out_y) + 0.5f) * height_scale)), in_h - 1),
          0);
      in_x = std::max<int64_t>(
          std::min<int64_t>(static_cast<int64_t>(floorf((static_cast<float>(out_x) + 0.5f) * width_scale)), in_w - 1),
          0);
    } else {
      in_frame = std::max<int64_t>(
          std::min<int64_t>(static_cast<int64_t>(floorf(static_cast<float>(out_frame) * frame_scale)), in_f - 1),
          0);
      in_y = std::max<int64_t>(
          std::min<int64_t>(static_cast<int64_t>(floorf(static_cast<float>(out_y) * height_scale)), in_h - 1),
          0);
      in_x = std::max<int64_t>(
          std::min<int64_t>(static_cast<int64_t>(floorf(static_cast<float>(out_x) * width_scale)), in_w - 1),
          0);
    }
    const Pack input_value = x[(((n * in_f + in_frame) * in_h + in_y) * in_w + in_x) * channels_packed + c];
    if constexpr (HasResidual) {
      y[idx] = {{ func }}_cpu_pack_add<Elem, Alignment>(input_value, residual[idx]);
    } else {
      y[idx] = input_value;
    }
  }
}

