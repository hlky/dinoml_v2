static int {{ func }}(
    const {{ cpu_storage_type }}* DINO_RESTRICT x,
    {{ cpu_storage_type }}* DINO_RESTRICT y,
    int64_t output_total) {
  if (x == nullptr || y == nullptr) {
    return dino_runtime_fail("{{ func }} received null pointer");
  }
  constexpr int64_t hidden = {{ hidden }};
  for (int64_t elem = 0; elem < output_total; ++elem) {
    const int64_t row = elem / hidden;
    const int64_t col = elem - row * hidden;
    const int64_t input_base = row * hidden * 2 + col;
    const float gate = dinoml::math::cast<float>(x[input_base]);
    const float up = dinoml::math::cast<float>(x[input_base + hidden]);
    const float sigmoid = 1.0f / (1.0f + std::exp(-gate));
    y[elem] = dinoml::math::cast<{{ cpu_storage_type }}>(up * gate * sigmoid);
  }
  return 0;
}
