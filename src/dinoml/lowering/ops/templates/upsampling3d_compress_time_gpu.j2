template <typename Elem>
__device__ __forceinline__ Elem {{ func }}_elem_add(Elem a, Elem b) {
  return a + b;
}

template <typename Vec, typename Elem>
__device__ __forceinline__ Vec {{ func }}_packed_add(const Vec& a, const Vec& b) {
  static_assert(sizeof(Vec) % sizeof(Elem) == 0, "Packed add requires compatible vector width");
  Vec out;
  auto* out_ptr = reinterpret_cast<Elem*>(&out);
  auto* a_ptr = reinterpret_cast<const Elem*>(&a);
  auto* b_ptr = reinterpret_cast<const Elem*>(&b);
  constexpr int lanes = sizeof(Vec) / sizeof(Elem);
#pragma unroll
  for (int lane = 0; lane < lanes; ++lane) {
    out_ptr[lane] = {{ func }}_elem_add<Elem>(a_ptr[lane], b_ptr[lane]);
  }
  return out;
}

template <typename Elem, typename Vec, int Alignment>
__global__ void {{ kernel }}_nearest(
    const Vec* DINO_RESTRICT x,
    Vec* DINO_RESTRICT y,
    int64_t batch,
    int64_t in_f,
    int64_t in_h,
    int64_t in_w,
    int64_t channels_packed,
    int64_t out_f,
    int64_t out_h,
    int64_t out_w) {
  const float height_scale = static_cast<float>(in_h) / static_cast<float>(out_h);
  const float width_scale = static_cast<float>(in_w) / static_cast<float>(out_w);
  const int64_t num_threads = batch * out_f * out_h * out_w * channels_packed;
  const int64_t stride = static_cast<int64_t>(blockDim.x) * static_cast<int64_t>(gridDim.x);
  for (int64_t idx = static_cast<int64_t>(blockIdx.x) * blockDim.x + threadIdx.x;
       idx < num_threads;
       idx += stride) {
    int64_t t = idx;
    const int64_t c = t % channels_packed;
    t /= channels_packed;
    const int64_t out_x = t % out_w;
    t /= out_w;
    const int64_t out_y = t % out_h;
    t /= out_h;
    const int64_t out_frame = t % out_f;
    const int64_t n = t / out_f;
    int64_t in_frame = 0;
    if (in_f == 1) {
      in_frame = 0;
    } else if ((in_f & 1LL) == 0) {
      in_frame = max(
          min(static_cast<int64_t>(floorf(static_cast<float>(out_frame) * (static_cast<float>(in_f) / static_cast<float>(out_f)))), in_f - 1),
          static_cast<int64_t>(0));
    } else if (out_frame == 0) {
      in_frame = 0;
    } else {
      in_frame = max(
          min(static_cast<int64_t>(1 + floorf(static_cast<float>(out_frame - 1) * 0.5f)), in_f - 1),
          static_cast<int64_t>(1));
    }
    const int64_t in_y = max(min(static_cast<int64_t>(floorf(static_cast<float>(out_y) * height_scale)), in_h - 1), static_cast<int64_t>(0));
    const int64_t in_x = max(min(static_cast<int64_t>(floorf(static_cast<float>(out_x) * width_scale)), in_w - 1), static_cast<int64_t>(0));
    y[idx] = LDG(x + (((n * in_f + in_frame) * in_h + in_y) * in_w + in_x) * channels_packed + c);
  }
}

