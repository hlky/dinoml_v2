template <typename Elem, int Alignment>
struct alignas(sizeof(Elem) * Alignment) {{ func }}_cpu_pack {
  Elem lanes[Alignment];
};

template <typename Elem, int Alignment>
inline void {{ func }}_cpu_nearest_packed(
    const Elem* x_raw,
    Elem* y_raw,
    int64_t batch,
    int64_t in_f,
    int64_t in_h,
    int64_t in_w,
    int64_t channels_packed,
    int64_t out_f,
    int64_t out_h,
    int64_t out_w) {
  using Pack = {{ func }}_cpu_pack<Elem, Alignment>;
  const Pack* x = reinterpret_cast<const Pack*>(x_raw);
  Pack* y = reinterpret_cast<Pack*>(y_raw);
  const float height_scale = static_cast<float>(in_h) / static_cast<float>(out_h);
  const float width_scale = static_cast<float>(in_w) / static_cast<float>(out_w);
#if defined(_OPENMP)
#pragma omp parallel for schedule(static)
#endif
  for (int64_t idx = 0; idx < batch * out_f * out_h * out_w * channels_packed; ++idx) {
    int64_t t = idx;
    const int64_t c = t % channels_packed;
    t /= channels_packed;
    const int64_t out_x = t % out_w;
    t /= out_w;
    const int64_t out_y = t % out_h;
    t /= out_h;
    const int64_t out_frame = t % out_f;
    const int64_t n = t / out_f;
    int64_t in_frame = 0;
    if (in_f == 1) {
      in_frame = 0;
    } else if ((in_f & 1LL) == 0) {
      in_frame = std::max<int64_t>(
          std::min<int64_t>(
              static_cast<int64_t>(floorf(static_cast<float>(out_frame) * (static_cast<float>(in_f) / static_cast<float>(out_f)))),
              in_f - 1),
          0);
    } else if (out_frame == 0) {
      in_frame = 0;
    } else {
      in_frame = std::max<int64_t>(
          std::min<int64_t>(static_cast<int64_t>(1 + floorf(static_cast<float>(out_frame - 1) * 0.5f)), in_f - 1),
          1);
    }
    const int64_t in_y = std::max<int64_t>(
        std::min<int64_t>(static_cast<int64_t>(floorf(static_cast<float>(out_y) * height_scale)), in_h - 1),
        0);
    const int64_t in_x = std::max<int64_t>(
        std::min<int64_t>(static_cast<int64_t>(floorf(static_cast<float>(out_x) * width_scale)), in_w - 1),
        0);
    y[idx] = x[(((n * in_f + in_frame) * in_h + in_y) * in_w + in_x) * channels_packed + c];
  }
}

static int {{ func }}(
    const {{ storage_type }}* DINO_RESTRICT x,
    const {{ storage_type }}* DINO_RESTRICT residual,
    {{ storage_type }}* DINO_RESTRICT y,
    int64_t runtime_numel,
    int64_t in_n,
    int64_t in_f,
    int64_t in_h,
    int64_t in_w,
    int64_t in_c,
    int64_t out_n,
    int64_t out_f,
    int64_t out_h,
    int64_t out_w,
    int64_t out_c) {
  (void)residual;
  if (x == nullptr || y == nullptr) {
    return dino_runtime_fail("{{ func }} received null pointer");
  }
  if (runtime_numel != out_n * out_f * out_h * out_w * out_c) {
    return dino_runtime_fail("{{ func }} received mismatched output element count");
  }
  if (in_n != out_n || in_c != out_c) {
    return dino_runtime_fail("{{ func }} requires matching batch and channel dimensions");
  }
  if ((in_c % {{ nearest_alignment }}) != 0) {
    return dino_runtime_fail("{{ func }} requires channels divisible by {{ nearest_alignment }} for packed nearest upsampling");
  }
  {{ func }}_cpu_nearest_packed<
      {{ storage_type }},
      {{ nearest_alignment }}>(
          x,
          y,
          in_n,
          in_f,
          in_h,
          in_w,
          in_c / {{ nearest_alignment }},
          out_f,
          out_h,
          out_w);
  return 0;
}
