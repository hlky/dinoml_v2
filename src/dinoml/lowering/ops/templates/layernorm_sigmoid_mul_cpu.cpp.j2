      const float scale = dinoml::math::cast<float>(weight[col]);
      const float shift = dinoml::math::cast<float>(bias[col]);
      const float normalized = (value - mean) * inv_std * scale + shift;
      const float fused = value / (1.0f + expf(-normalized));
      y[base + col] = dinoml::math::cast<{{ cpu_storage_type }}>(fused);
    }
  }
  return 0;
}
